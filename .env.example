# Twilio SMS Configuration
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
PARENT_PHONE_NUMBER=+1234567890

# Camera Settings
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Detection Settings
CHECK_INTERVAL=2.0
MEDIAPIPE_CONFIDENCE_HIGH=0.6
MEDIAPIPE_CONFIDENCE_MEDIUM=0.3
MOTION_THRESHOLD=5000.0
CONTOUR_MIN_AREA=1000

# Alert Settings
ALERT_RATE_LIMIT=5
ALERT_CONFIDENCE=0.5

# Logging
LOG_LEVEL=INFO
LOG_FILE=baby_monitor.log
LOG_TO_CONSOLE=True
